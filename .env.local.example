# ──────────────────────────────────────────────────────────────
#  Copy this file to ".env.local" and fill in your Supabase keys.
#  Find them in: Supabase Dashboard → Project Settings → API
# ──────────────────────────────────────────────────────────────

# Public — safe to expose to the browser (used by the app)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only — NEVER expose to the browser. Used by /admin actions.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# Admin login code for the /admin panel (choose anything)
ADMIN_CODE=biggame-admin
